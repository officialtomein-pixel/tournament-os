# ── Discord ────────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_client_id

# ── Database ───────────────────────────────────────────────────────────────────
# Plain postgresql:// or postgres:// are auto-converted to asyncpg format.
# Railway, Render, Supabase, Heroku, Neon, etc. all provide this format — just paste it.
DATABASE_URL=postgresql://user:password@localhost:5432/tournament_os

# ── AI ─────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile   # optional override

# ── Web Security ───────────────────────────────────────────────────────────────
# V1: single shared bearer token for staff dashboard access.
# Generate with: openssl rand -hex 32
ADMIN_DASHBOARD_TOKEN=change_me_to_a_long_random_string
SECRET_KEY=change_me_to_another_long_random_string

# ── App ────────────────────────────────────────────────────────────────────────
ENVIRONMENT=production     # development | production
WEB_HOST=0.0.0.0
WEB_PORT=8000              # ignored when PORT is set (Railway/Render inject PORT automatically)
LOG_LEVEL=INFO
